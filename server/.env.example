DATABASE_URL="postgresql://postgres:postgres@localhost:5432/findmymaid"
JWT_SECRET="replace-with-long-random-string-at-least-32-chars"
PORT=3000
HOST=0.0.0.0

# SMS OTP (Twilio Verify). Optional PHONE_DEFAULT_CC for numbers without +country (default 91).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=
# PHONE_DEFAULT_CC=91

# Local dev without Twilio: skips real SMS and accepts any 6+ digit code on verify.
# OTP_DEV_BYPASS=true
